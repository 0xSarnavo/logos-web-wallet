# ============================================================================
# Logos Wallet — environment template
# Copy to `.env.local` (gitignored) and adjust.
# ============================================================================

# ── Logos node HTTP API ──────────────────────────────────────────────────────
# Read-only chain/balance queries. The dashboard-style node API.
NODE_API=http://localhost:8080

# ── LEZ wallet backend ───────────────────────────────────────────────────────
# How account creation / transfers / proof generation are executed.
#   cli      → shell out to the local `wallet` CLI (logos-execution-zone)
#   sequencer→ POST transfers straight to the standalone sequencer HTTP API
# Start with `cli` once `wallet` is installed; `sequencer` is a thinner path.
WALLET_BACKEND=cli

# Path to the `wallet` binary (from `cargo install --path wallet`). If on PATH,
# leave as just "wallet".
WALLET_BIN=wallet

# Wallet home (where storage.json lives). Matches the CLI default.
WALLET_HOME=

# Standalone sequencer HTTP API (used when WALLET_BACKEND=sequencer, and for
# submitting signed transfers).
SEQUENCER_API=http://localhost:3040

# ── Safety ───────────────────────────────────────────────────────────────────
# Private transfers generate a ZK proof locally and can take MINUTES.
# Max seconds to wait on a proof-generating CLI call before timing out.
PROOF_TIMEOUT_SECONDS=600
